# Copy to .env.local (gitignored) for local dev. NEVER commit real secrets.
# In production these come from Bitwarden Secrets Manager (see infra/secrets.md).

# --- Supabase local stack (defaults from `supabase start`) ---
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
# JWT secret the local stack signs with (from `supabase status`). The API re-signs
# per-request user JWTs with this same secret (D44 bridge).
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
# Service-role key — permitted ONLY for migrations/system workers/admin (D44). Not on user paths.
SUPABASE_SERVICE_ROLE_KEY=

# --- Entra ID (SPA + API). Placeholders — see infra/entra.md ---
ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
ENTRA_API_CLIENT_ID=00000000-0000-0000-0000-000000000000
ENTRA_API_AUDIENCE=api://brunetco-os
# Set to 1 to bypass Entra validation for local dev (mock identity). Never in prod.
AUTH_DEV_MODE=1

# --- Web (Vite reads VITE_-prefixed vars) ---
VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
VITE_ENTRA_SPA_CLIENT_ID=00000000-0000-0000-0000-000000000000
VITE_ENTRA_API_SCOPE=api://brunetco-os/access_as_user

# --- Bitwarden Secrets Manager (production secret source, D10) ---
BWS_ACCESS_TOKEN=
BWS_PROJECT_ID=
